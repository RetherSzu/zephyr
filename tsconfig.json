{
    "extends": "./node_modules/gts/tsconfig-google.json",
    "compilerOptions": {
        "rootDir": ".",
        "outDir": "build",
        "skipLibCheck": true,
        "types": ["vite/client"],
        "jsx": "react-jsx",
        "lib": ["ES2023", "DOM"],
        "noEmit": true,
        "allowImportingTsExtensions": true,
        "paths": {
            "@/*": ["./src/*"]
        }
    },
    "include": ["src/**/*.ts", "src/**/*.tsx", "test/**/*.ts"]
}
